From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: alina sireneva <alina@tei.su>
Date: Thu, 23 Apr 2026 18:09:31 +0300
Subject: [PATCH] hooks inside admin logs activity

---
 .../src/main/java/org/telegram/messenger/MessageObject.java   | 1 +
 .../main/java/org/telegram/ui/ChannelAdminLogActivity.java    | 4 ++++
 2 files changed, 5 insertions(+)

diff --git a/TMessagesProj/src/main/java/org/telegram/messenger/MessageObject.java b/TMessagesProj/src/main/java/org/telegram/messenger/MessageObject.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/messenger/MessageObject.java
+++ b/TMessagesProj/src/main/java/org/telegram/messenger/MessageObject.java
@@ -3444,6 +3444,7 @@ public class MessageObject {
                 messageObject.linkDescription = null;
                 messageObject.generateLinkDescription();
             }
+            desu.inugram.helpers.AdminLogHelper.injectBubbles(currentAccount, event, messageObjects, chat, mid, addToEnd);
         }
         if (event.action instanceof TLRPC.TL_channelAdminLogEventActionDeleteMessage) {
             return;
diff --git a/TMessagesProj/src/main/java/org/telegram/ui/ChannelAdminLogActivity.java b/TMessagesProj/src/main/java/org/telegram/ui/ChannelAdminLogActivity.java
index 0000000..0000000 100644
--- a/TMessagesProj/src/main/java/org/telegram/ui/ChannelAdminLogActivity.java
+++ b/TMessagesProj/src/main/java/org/telegram/ui/ChannelAdminLogActivity.java
@@ -1790,6 +1790,7 @@ public class ChannelAdminLogActivity extends BaseFragment implements Notificatio
                 options.add(OPTION_CALL);
             }
         }
+        desu.inugram.helpers.AdminLogHelper.addMenuItems(items, options, icons, selectedObject);
 
         boolean callbackSent = false;
 
@@ -2091,6 +2092,9 @@ public class ChannelAdminLogActivity extends BaseFragment implements Notificatio
         if (selectedObject == null) {
             return;
         }
+        if (desu.inugram.helpers.AdminLogHelper.processMenuOption(option, this, selectedObject)) {
+            return;
+        }
         switch (option) {
             case OPTION_COPY: {
                 AndroidUtilities.addToClipboard(getMessageContent(selectedObject, 0, true));
-- 
2.52.0

